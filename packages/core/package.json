{
  "name": "@claude-manager/core",
  "version": "0.1.0",
  "private": false,
  "description": "Headless library for collecting live Claude Code session data",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/internal/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nesalia-labs/claude-manager.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nesalia-labs/claude-manager/issues"
  },
  "homepage": "https://github.com/nesalia-labs/claude-manager#readme",
  "keywords": [
    "claude-code",
    "tui",
    "dashboard",
    "monitor",
    "windows",
    "read-only"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo coverage *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "memfs": "^4.11.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5"
  }
}