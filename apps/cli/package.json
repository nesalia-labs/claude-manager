{
  "name": "@claude-manager/cli",
  "version": "0.1.0",
  "private": false,
  "description": "Windows terminal dashboard for monitoring live Claude Code sessions",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "claude-manager": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/index.js",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@claude-manager/core": "workspace:*",
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "commander": "^12.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5"
  }
}